    "extract_dir": "Phoenix\\windows",
    "post_install": [
        "$firefoxPath = appdir 'firefox-eme-free'",
        "New-Item -ItemType HardLink -Target \"$dir\\phoenix.cfg\" -Path \"$firefoxPath\\current\\phoenix.cfg\" -Force | Out-Null",
