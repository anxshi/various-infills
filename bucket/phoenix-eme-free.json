    "post_install": [
        "$firefoxPath = persistdir 'firefox-eme-free'",
        "New-Item -ItemType HardLink -Target \"$dir\\phoenix.cfg\" -Path \"$firefoxPath\\current\\phoenix.cfg\" -Force | Out-Null",
        "New-Item -ItemType HardLink -Target \"$dir\\defaults\\pref\\phoenix.js\" -Path \"$firefoxPath\\current\\defaults\\pref\\phoenix.js\" -Force | Out-Null",
        "New-Item -ItemType HardLink -Target \"$dir\\distribution\\policies.json\" -Path \"$firefoxPath\\current\\distribution\\policies.json\" -Force | Out-Null"
    ],
    "checkver": {
        "url": "https://codeberg.org/api/v1/repos/celenity/phoenix/releases/latest",
